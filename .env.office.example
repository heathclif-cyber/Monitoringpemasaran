# Salin ke .env.office atau merge ke .env untuk deploy PC kantor (gratis, IP LAN).
# Akses: http://<IP-PC-KANTOR>:8000  (contoh http://192.168.1.50:8000)

# --- Postgres lokal (Docker compose) ---
POSTGRES_USER=ptpn
POSTGRES_PASSWORD=PtpnKantor_Local_ChangeMe
POSTGRES_DB=monitoringpemasaran

# App native (tanpa Docker) — sesuaikan host:
# DATABASE_URL=postgresql://ptpn:PtpnKantor_Local_ChangeMe@127.0.0.1:5432/monitoringpemasaran

SECRET_KEY=ganti-secret-panjang-acak-untuk-kantor
RUN_DB_MIGRATE=true

# Superman (Playwright di PC kantor yang sama)
SUPERMAN_URL=https://superman.ptpn1.co.id/
SUPERMAN_USER=
SUPERMAN_PASSWORD=
SUPERMAN_HEADLESS=true
SUPERMAN_DEFAULT_EXECUTOR=server

# Path data (native Windows)
# SUPERMAN_STATE_PATH=D:\Apps-Dev\Monitoringpemasaran\data\.superman_state.json
# UPLOAD_DIR=D:\Apps-Dev\Monitoringpemasaran\uploads
