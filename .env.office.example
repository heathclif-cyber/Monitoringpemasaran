# Template env untuk deploy PC kantor (Docker Compose).
# Salin ke .env di root repo (file .env tidak di-commit):
#   copy .env.office.example .env
# Atau pakai: scripts\office\setup_env.ps1
#
# Akses lokal:  http://localhost:8000
# Akses LAN:    http://<IP-PC>:8000
# Akses internet: Cloudflare Tunnel → lihat DEPLOY_GUIDE.md Phase 4

# --- Postgres (dibaca docker-compose.yml) ---
POSTGRES_USER=ptpn
POSTGRES_PASSWORD=GantiPasswordMin16KarakterAlfanumerik
POSTGRES_DB=monitoringpemasaran

# --- App ---
SECRET_KEY=ganti-secret-panjang-acak-minimal-32-karakter
RUN_DB_MIGRATE=true

# Native Windows saja (tanpa Docker) — jangan set bersamaan dengan compose DATABASE_URL otomatis:
# DATABASE_URL=postgresql://ptpn:GantiPasswordMin16KarakterAlfanumerik@127.0.0.1:5432/monitoringpemasaran

# --- Superman (Playwright di PC server) ---
SUPERMAN_URL=https://superman.ptpn1.co.id/
SUPERMAN_USER=
SUPERMAN_PASSWORD=
SUPERMAN_HEADLESS=true
SUPERMAN_DEFAULT_EXECUTOR=server

# Path native Windows (opsional):
# SUPERMAN_STATE_PATH=D:\Apps-Dev\Monitoringpemasaran\data\.superman_state.json
# UPLOAD_DIR=D:\Apps-Dev\Monitoringpemasaran\uploads
